# Public URL for the self-hosted deployment.
APP_URL=http://localhost:8114
CMDCLAW_MCP_BASE_URL=http://localhost:3010
CMDCLAW_EDITION=selfhost
VITE_CMDCLAW_EDITION=selfhost
CMDCLAW_CLOUD_API_BASE_URL=http://localhost:3000
CMDCLAW_CLOUD_INSTANCE_API_KEY=replace-with-shared-instance-api-key

NODE_ENV=production

# Optional published image overrides. Defaults already point at these GHCR tags.
# CMDCLAW_APP_IMAGE=ghcr.io/baptistecolle/cmdclaw-web:main
# CMDCLAW_WORKER_IMAGE=ghcr.io/baptistecolle/cmdclaw-worker:main

# Generate with:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-64-char-hex-secret
ENCRYPTION_KEY=replace-with-64-char-hex-secret
CMDCLAW_SERVER_SECRET=replace-with-64-char-hex-secret

# Core data services
DATABASE_URL=postgresql://postgres:postgres@database:5432/cmdclaw
# Optional alternate targets for manual schema pushes
# DATABASE_URL_STAGING=postgresql://postgres:postgres@staging:5432/cmdclaw
# DATABASE_URL_PROD=postgresql://postgres:postgres@prod:5432/cmdclaw
REDIS_URL=redis://redis:6379
BULLMQ_QUEUE_NAME=cmdclaw-default

# LLM providers
OPENAI_API_KEY=replace-with-openai-key
ANTHROPIC_API_KEY=replace-with-anthropic-key

# Sandboxing
SANDBOX_AGENT_RUNTIME=agentsdk
SANDBOX_DEFAULT=docker
# DAYTONA_API_KEY=
# DAYTONA_API_URL=http://localhost:3300/api
# DAYTONA_TARGET=us

# S3-compatible storage (MinIO by default in docker-compose.selfhost.yml)
AWS_ENDPOINT_URL=http://minio:9000
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET_NAME=cmdclaw-documents
AWS_S3_FORCE_PATH_STYLE=true

# Optional email delivery. If left unset, magic links will be logged by the app container.
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
# EMAIL_FROM=noreply@example.com
# RESEND_RECEIVING_DOMAIN=

# Optional telemetry
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=
# POSTHOG_API_KEY=
# POSTHOG_HOST=
#
# Optional executor tracing for sandbox-local `executor server start`.
# The OTLP endpoint must be reachable from inside the sandbox.
# For E2B or Daytona cloud sandboxes, use a public host instead of `localhost` or `jaeger`.
# EXECUTOR_TRACE_ENABLED=1
# EXECUTOR_TRACE_SERVICE_NAME=cmdclaw-sandbox-executor
# EXECUTOR_TRACE_OTLP_ENDPOINT=http://your-trace-host:4317
# EXECUTOR_TRACE_QUERY_BASE_URL=http://your-trace-host:16686

# Optional integrations
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# AIRTABLE_CLIENT_ID=
# AIRTABLE_CLIENT_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_APP_BUNDLE_IDENTIFIER=
# DISCORD_BOT_TOKEN=
# UNIPILE_API_KEY=
# UNIPILE_DSN=
# FAL_KEY=
# DEEPGRAM_API_KEY=
# GEMINI_API_KEY=
# AUTUMN_SECRET_KEY=
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_BOT_OWNER_USER_ID=
# SLACK_BOT_RELAY_SECRET=
# SLACK_BOT_RELAY_ALLOWED_CHANNELS=
# COMMUNITY_REPO_GITHUB_TOKEN=
