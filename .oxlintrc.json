{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "off"
  },
  "jsPlugins": ["./oxlint-plugins/local.mjs"],
  "rules": {
    "max-lines": ["error", { "max": 1000 }],
    "local/no-product-organization-import": [
      "error",
      {
        "allow": [
          "packages/db/src/auth-schema.ts",
          "packages/db/src/schema/tables-auth.ts",
          "packages/db/src/schema/tables.ts",
          "packages/db/src/schema/relations.ts",
          "apps/web/src/lib/auth.ts",
          "apps/web/src/lib/auth-client.ts"
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.e2e.test.ts", "**/*.e2e.test.tsx"],
      "rules": {
        "local/max-mocked-modules": ["error", { "max": 10 }]
      }
    }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.output/**",
    "**/.tanstack/**",
    "**/out/**",
    "**/build/**",
    "**/.turbo/**",
    ".turbo-prune-web/**",
    ".claude/**",
    ".worktrees/**",
    ".agents/**",
    "experiments/**",
    "**/*.gen.ts"
  ]
}
