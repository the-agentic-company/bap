{
  "name": "@bap/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth-schema": "./src/auth-schema.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./template-catalog": "./src/template-catalog.ts"
  },
  "scripts": {
    "build": "bunx tsc --noEmit -p tsconfig.json",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun --env-file=../../.env src/ensure-extensions.ts && bun --env-file=../../.env drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "bun --env-file=../../.env src/ensure-extensions.ts && bun --env-file=../../.env drizzle-kit push --config=drizzle.config.ts",
    "db:push:prod": "bun --env-file=../../.env scripts/db-push.ts prod",
    "db:push:staging": "bun --env-file=../../.env scripts/db-push.ts staging",
    "db:recreate": "bun run db:reset && bun run db:seed",
    "db:reset": "bun --env-file=../../.env src/reset.ts",
    "db:seed": "bun --env-file=../../.env src/seed.ts",
    "db:seed:coworker-backlog": "bun --env-file=../../.env src/seed-coworker-backlog.ts",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio --config=drizzle.config.ts",
    "db:studio:prod": "bun --env-file=../../.env scripts/db-studio.ts prod",
    "db:studio:staging": "bun --env-file=../../.env scripts/db-studio.ts staging"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.10"
  }
}
