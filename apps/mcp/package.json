{
  "name": "@cmdclaw/mcp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "bun run build:internal && bun run build:gmail && bun run build:galien && bun run build:modulr && bun run build:gateway",
    "build:internal": "cd servers/internal && ../../node_modules/.bin/xmcp build",
    "build:gmail": "cd servers/gmail && ../../node_modules/.bin/xmcp build",
    "build:galien": "cd servers/galien && ../../node_modules/.bin/xmcp build",
    "build:modulr": "cd servers/modulr && ../../node_modules/.bin/xmcp build",
    "build:gateway": "bun build gateway/src/index.ts --outfile gateway/dist/index.js --target bun",
    "dev": "bun run dev:all",
    "dev:all": "MCP_GATEWAY_MANAGED_CHILDREN=true MCP_GATEWAY_CHILD_MODE=start MCP_GATEWAY_PORT=3010 bun --env-file=../../.env run gateway/src/index.ts",
    "dev:managed": "MCP_GATEWAY_MANAGED_CHILDREN=true MCP_GATEWAY_PORT=3010 bun --env-file=../../.env run gateway/src/index.ts",
    "dev:internal": "cd servers/internal && ../../node_modules/.bin/xmcp dev",
    "dev:gmail": "cd servers/gmail && ../../node_modules/.bin/xmcp dev",
    "dev:galien": "cd servers/galien && ../../node_modules/.bin/xmcp dev",
    "dev:modulr": "cd servers/modulr && ../../node_modules/.bin/xmcp dev",
    "dev:gateway": "bun run gateway/src/index.ts",
    "start": "bun run start:gateway",
    "start:all": "MCP_GATEWAY_MANAGED_CHILDREN=true MCP_GATEWAY_CHILD_MODE=start bun --env-file=../../.env run gateway/dist/index.js",
    "start:internal": "bun servers/internal/dist/http.js",
    "start:gmail": "bun servers/gmail/dist/http.js",
    "start:galien": "bun servers/galien/dist/http.js",
    "start:modulr": "bun servers/modulr/dist/http.js",
    "start:gateway": "bun gateway/dist/index.js",
    "check": "bunx tsc --noEmit -p tsconfig.json && bunx tsc --noEmit -p servers/internal/tsconfig.json && bunx tsc --noEmit -p servers/gmail/tsconfig.json && bunx tsc --noEmit -p servers/galien/tsconfig.json && bunx tsc --noEmit -p servers/modulr/tsconfig.json",
    "test": "bun run test:unit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@cmdclaw/client": "workspace:*",
    "@cmdclaw/core": "workspace:*",
    "@cmdclaw/message-format": "workspace:*",
    "xmcp": "0.6.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
