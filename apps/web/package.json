{
  "name": "@bap/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:generate": "bun x @better-auth/cli@latest generate --output ../../packages/db/src/auth-schema.ts -y",
    "auth:inspect": "bun scripts/auth-inspect.ts",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 bun --env-file=../../.env vite build",
    "chat:auth": "bun --env-file=../../.env --cwd ../cli src/bin/bap.ts auth login",
    "check": "bun run typecheck && bun run lint",
    "dev": "bun --env-file=../../.env vite dev --host 0.0.0.0 --port 3000",
    "dev:selfhost": "BAP_EDITION=selfhost bun --env-file=../../.env.selfhost vite dev --port 3001",
    "docker-up:local": "docker compose -f ../../docker/compose/dev.yml up",
    "experiment:sandbox-agent:e2b-trace": "bun experiments/sandbox-agent-e2b-trace.ts",
    "experiment:sandbox-agent:quickstart": "bun experiments/sandbox-agent-quickstart.ts",
    "experiment:sandbox-agent:sdk-overview": "bun experiments/sandbox-agent-sdk-overview.ts",
    "experiment:sandbox-agent:skills-config": "bun experiments/sandbox-agent-skills-config.ts",
    "format": "bunx --bun oxfmt --write \"**/*.{ts,tsx,js,jsx,mdx}\"",
    "format:check": "bunx --bun oxfmt --check \"**/*.{ts,tsx,js,jsx,mdx}\"",
    "format:write": "bunx --bun oxfmt --write \"**/*.{ts,tsx,js,jsx,mdx}\"",
    "lint": "bunx --bun oxlint .",
    "lint:fix": "bunx --bun oxlint --fix .",
    "models:opencode:free": "bun scripts/list-opencode-free-models.ts",
    "monitor:playwright:kuma": "bun --env-file=../../.env scripts/monitoring-playwright-kuma.ts",
    "profiler": "bun scripts/profiler.ts",
    "slo:backfill:prod": "bun --env-file=../../.env scripts/slo-backfill.ts",
    "slo:replay": "bun --env-file=../../.env scripts/slo-replay.ts",
    "start": "node --env-file=../../.env .output/server/index.mjs",
    "test": "bun run test:integration",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:e2e && bun run test:live",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "COVERAGE_CHECK=1 vitest run --coverage",
    "test:e2e": "bun scripts/e2e-live.ts smoke-stable",
    "test:e2e:auth": "bun scripts/e2e-live.ts auth",
    "test:e2e:cli:live": "bun scripts/e2e-live.ts cli-live",
    "test:e2e:interactive": "bun --env-file=../../.env scripts/e2e-interactive.ts",
    "test:e2e:live": "bun scripts/e2e-live.ts live",
    "test:e2e:live:prod": "bun scripts/e2e-live.ts prod",
    "test:e2e:live:prod:monitor": "bun scripts/e2e-live.ts prod-monitor",
    "test:e2e:live:record": "bun scripts/e2e-live.ts record",
    "test:integration": "vitest run",
    "test:interactive": "bun run test:e2e:interactive",
    "test:live": "bun run test:live:auth",
    "test:live:auth": "bun run test:e2e:auth",
    "test:live:cli": "bun scripts/e2e-live.ts cli-live-stable",
    "test:live:web": "bun scripts/e2e-live.ts live-stable",
    "test:monitor": "bun scripts/e2e-live.ts prod-monitor-stable",
    "test:prod": "bun scripts/e2e-live.ts prod-stable",
    "test:record": "bun run test:e2e:live:record",
    "test:replay:release": "bun scripts/release-replay.ts",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "tool": "bun run chat:auth && bun --env-file=../../.env scripts/tool.ts",
    "typecheck": "tsgo --noEmit"
  },
