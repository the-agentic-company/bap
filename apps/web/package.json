{
  "name": "@cmdclaw/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "auth:generate": "bun x @better-auth/cli@latest generate --output ../../packages/db/src/auth-schema.ts -y",
    "auth:inspect": "bun scripts/auth-inspect.ts",
    "build": "bun --env-file=../../.env next build",
    "chat:auth": "bun --env-file=../../.env --cwd ../cli src/bin/cmdclaw.ts auth login",
    "check": "bun run typecheck && bun run lint",
    "db:generate": "bun run --cwd ../../packages/db db:generate",
    "db:migrate": "bun run --cwd ../../packages/db --env-file=../../.env db:migrate",
    "db:prod:push": "bun run db:push:prod",
    "db:push": "bun run --cwd ../../packages/db --env-file=../../.env db:push",
    "db:push:prod": "bun --env-file=../../.env scripts/db-push.ts prod",
    "db:push:staging": "bun --env-file=../../.env scripts/db-push.ts staging",
    "db:recreate": "bun run db:reset && bun run db:seed",
    "db:reset": "bun run --cwd ../../packages/db --env-file=../../.env reset",
    "db:seed": "bun run --cwd ../../packages/db --env-file=../../.env seed",
    "db:studio": "bun run --cwd ../../packages/db --env-file=../../.env db:studio",
