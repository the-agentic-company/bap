{
  "name": "@cmdclaw/sandbox",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./paths": "./src/paths.ts",
    "./plugins/*": "./src/common/plugins/*.ts",
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bunx tsc --noEmit -p tsconfig.json",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "daytona:build:dev": "bun --env-file=../../.env src/daytona/build.dev.ts",
    "daytona:build:staging": "bun --env-file=../../.env src/daytona/build.staging.ts",
    "daytona:build:prod": "bun --env-file=../../.env src/daytona/build.prod.ts",
    "daytona:cleanup": "bun --env-file=../../.env scripts/daytona-cleanup.ts",
    "daytona:selfhost:smoke": "bun --env-file=../../.env scripts/daytona-selfhost-smoke.ts",
    "daytona:sandbox": "bun --env-file=../../.env scripts/daytona-sandbox.ts",
    "daytona:sandbox:kill": "bun --env-file=../../.env scripts/daytona-sandboxes.ts kill",
    "daytona:sandbox:kill-all": "bun --env-file=../../.env scripts/daytona-sandboxes.ts kill-all",
    "daytona:sandbox:list": "bun --env-file=../../.env scripts/daytona-sandboxes.ts list",
    "e2b:build:dev": "bun --env-file=../../.env src/e2b/build.dev.ts",
    "e2b:build:prod": "bun --env-file=../../.env src/e2b/build.prod.ts",
    "e2b:build:staging": "bun --env-file=../../.env src/e2b/build.staging.ts",
    "e2b:sandbox": "bun --env-file=../../.env scripts/test-sandbox.ts",
    "e2b:sandbox:kill": "bun --env-file=../../.env scripts/e2b-sandboxes.ts kill",
    "e2b:sandbox:kill-all": "bun --env-file=../../.env scripts/e2b-sandboxes.ts kill-all",
    "e2b:sandbox:list": "bun --env-file=../../.env scripts/e2b-sandboxes.ts list",
    "test:unit": "vitest run --config vitest.config.ts scripts/test-sandbox.test.ts scripts/daytona-sandbox.test.ts src/daytona/build.test.ts",
    "test:live": "bun --env-file=../../.env vitest run src/common/opencode-agents.live.test.ts"
  },
  "dependencies": {
    "@cmdclaw/db": "workspace:*",
    "@cmdclaw/message-format": "workspace:*",
    "@daytonaio/sdk": "^0.144.0",
    "@opencode-ai/plugin": "^1.2.10",
    "@opencode-ai/sdk": "^1.1.34",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "e2b": "^2.12.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
