FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
ARG OPENCODE_VERSION=1.3.0
WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    curl \
    git \
    ripgrep \
    ca-certificates \
    gnupg \
    unzip \
    python3 \
    python3-venv \
    python3-pip \
    python-is-python3 \
  && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get update \
  && apt-get install -y --no-install-recommends nodejs \
  && rm -rf /var/lib/apt/lists/*

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    libxcb-shm0 \
    libx11-xcb1 \
    libx11-6 \
    libxcb1 \
    libxext6 \
    libxrandr2 \
    libxcomposite1 \
    libxcursor1 \
    libxdamage1 \
    libxfixes3 \
    libxi6 \
    libgtk-3-0 \
    libpangocairo-1.0-0 \
    libpango-1.0-0 \
    libatk1.0-0 \
    libcairo-gobject2 \
    libcairo2 \
    libgdk-pixbuf-2.0-0 \
    libxrender1 \
    libasound2t64 \
    libfreetype6 \
    libfontconfig1 \
    libdbus-1-3 \
    libnss3 \
    libnspr4 \
    libatk-bridge2.0-0 \
    libdrm2 \
    libxkbcommon0 \
    libatspi2.0-0 \
    libcups2 \
    libxshmfence1 \
    libgbm1 \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g agent-browser playwright \
  && playwright install chromium \
  && CHROMIUM_BIN="$(find "$PLAYWRIGHT_BROWSERS_PATH" -type f \( -path '*/chrome-linux/chrome' -o -path '*/chrome-linux64/chrome' \) | head -n 1)" \
  && test -n "$CHROMIUM_BIN" \
  && ln -sf "$CHROMIUM_BIN" /usr/local/bin/chromium
ENV AGENT_BROWSER_EXECUTABLE_PATH=/usr/local/bin/chromium

RUN curl -fsSL https://bun.sh/install | bash
RUN ln -s /root/.bun/bin/bun /usr/local/bin/bun
RUN /root/.bun/bin/bun install -g opencode-ai@${OPENCODE_VERSION} tsx
RUN ln -s /root/.bun/bin/opencode /usr/local/bin/opencode
RUN ln -s /root/.bun/bin/tsx /usr/local/bin/tsx

RUN npm install -g @sandbox-agent/cli@0.2.x \
  && sandbox-agent install-agent opencode

COPY common/opencode.json /app/opencode.json
COPY common/agents /app/.opencode/agents
COPY common/plugins /app/.opencode/plugins
COPY common/tools /app/.opencode/tools
COPY common/lib /app/.opencode/lib
COPY common/skills /app/.agents/skills
COPY common/lib /app/.agents/lib
COPY common/setup.sh /app/setup.sh

RUN mkdir -p /app/.claude \
  && ln -sfn /app/.agents/skills /app/.claude/skills \
  && mkdir -p /root/.config/opencode /app/.opencode /root/.cache/opencode \
  && cp /app/opencode.json /app/.opencode/opencode.json

RUN bash -lc 'cd /app && printf "{\"name\":\"sandbox-runtime\",\"private\":true}\\n" > package.json && bun install @opencode-ai/plugin'
RUN chmod +x /app/setup.sh && /app/setup.sh

CMD ["bash", "-lc", "sleep infinity"]
