{
  "name": "@cmdclaw/worktree",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "cli": "bun src/cli.ts",
    "dev": "bun --watch --env-file=../../.env src/proxy.ts",
