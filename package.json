{
  "name": "bap",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "cat": "bun scripts/cat.ts",
    "decrypt": "bun --env-file=.env scripts/decrypt-files.ts",
    "cli": "bun --env-file=.env apps/cli/src/bin/bap.ts",
    "bap": "bun --env-file=.env apps/cli/src/bin/bap.ts",
    "env": "infisical export --output-file=.env",
    "dev": "bun --env-file=.env turbo dev --filter=@bap/web --filter=@bap/worker --filter=@bap/ws --filter=@bap/mcp --filter=@bap/local-tunnel --ui=tui",
    "dev:timed": "bash -lc 'set -o pipefail; FORCE_COLOR=1 CLICOLOR_FORCE=1 bun --env-file=.env turbo run dev --filter=@bap/web --filter=@bap/worker --filter=@bap/ws --filter=@bap/mcp --ui=stream --log-prefix=task --log-order=stream --color 2>&1 | perl -ne '\\''BEGIN { $| = 1 } chomp; @t = localtime; printf(\"[%04d-%02d-%02d %02d:%02d:%02d] %s\\n\", $t[5] + 1900, $t[4] + 1, $t[3], $t[2], $t[1], $t[0], $_);'\\'''",
    "dev:selfhost": "bun --env-file=.env.selfhost turbo dev:selfhost --filter=@bap/web --filter=@bap/worker --filter=@bap/ws --ui=tui",
    "dev:selfhost:web": "bun --env-file=.env.selfhost turbo dev:selfhost --filter=@bap/web",
    "build": "turbo build",
    "check": "turbo check",
    "lint:size": "bun scripts/lint-size-baseline.ts",
    "lint:mocks": "bun scripts/lint-size-baseline.ts -A max-lines",
    "test": "bun run test:ci",
    "test:ui": "vitest --config vitest.ui.config.ts --ui --open",
    "dev:web": "bun --env-file=.env turbo dev --filter=@bap/web",
    "dev:docs": "turbo dev --filter=@bap/docs",
    "dev:worker": "bun --env-file=.env turbo dev --filter=@bap/worker",
    "dev:ws": "bun --env-file=.env turbo dev --filter=@bap/ws",
    "dev:mcp": "bun --env-file=.env turbo dev --filter=@bap/mcp",
    "start:web": "bun --env-file=.env run --cwd apps/web start",
    "start:worker": "bun --env-file=.env run --cwd apps/worker start",
    "start:ws": "bun --env-file=.env run --cwd apps/ws start",
    "start:mcp": "bun run --cwd apps/mcp start",
    "build:web": "turbo build --filter=@bap/web",
    "build:cli": "turbo build --filter=@bap/cli",
    "build:docs": "turbo build --filter=@bap/docs",
    "build:mcp": "turbo build --filter=@bap/mcp",
    "build:worker": "turbo build --filter=@bap/worker",
    "build:ws": "turbo build --filter=@bap/ws",
    "workflow": "bun run --cwd apps/web workflow",
    "observability:validate-generation": "bun scripts/validate-generation-observability.ts",
    "check:cli": "turbo check --filter=@bap/cli",
    "cli:e2e:live:record": "bun run --cwd apps/web test:e2e:live:record",
    "check:web": "turbo check --filter=@bap/web",
    "check:docs": "turbo check --filter=@bap/docs",
    "check:mcp": "turbo check --filter=@bap/mcp",
    "check:worker": "turbo check --filter=@bap/worker",
    "check:ws": "turbo check --filter=@bap/ws",
    "test:all": "bun run test:ci && bun run test:live && bun run --cwd apps/web test:e2e:cli:live",
    "test:ci": "bun run test:unit && bun run test:integration",
    "test:e2e": "turbo run test:e2e --filter=@bap/web",
    "test:e2e:cli:live": "bun run --cwd apps/web test:e2e:cli:live",
    "test:integration": "turbo run test:integration --filter=@bap/web",
    "test:interactive": "turbo run test:interactive --filter=@bap/web",
    "test:live": "turbo run test:live --filter=@bap/web",
    "test:live:auth": "turbo run test:live:auth --filter=@bap/web",
    "test:live:cli": "turbo run test:live:cli --filter=@bap/web",
    "test:live:web": "turbo run test:live:web --filter=@bap/web",
    "test:monitor": "turbo run test:monitor --filter=@bap/web",
    "test:prod": "turbo run test:prod --filter=@bap/web",
    "test:record": "turbo run test:record --filter=@bap/web",
    "test:unit": "turbo run test:unit --filter=@bap/cli --filter=@bap/mcp --filter=@bap/client --filter=@bap/core --filter=@bap/message-format --filter=@bap/web",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^2.2.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.207.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.207.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.37.0"
  },
  "devDependencies": {
    "@vitest/ui": "4.0.18",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "turbo": "^2.8.16",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.9",
  "patchedDependencies": {
    "drizzle-kit@0.31.10": "patches/drizzle-kit@0.31.10.patch"
  },
  "overrides": {
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/exporter-prometheus": "0.218.0",
    "@opentelemetry/sdk-node": "0.218.0",
    "esbuild": "0.27.7",
    "protobufjs": "8.6.3",
    "uuid": "11.1.1",
    "vite": "8.0.16"
  }
}
